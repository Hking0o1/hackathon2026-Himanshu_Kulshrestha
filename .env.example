# LLM Providers
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash
HUGGINGFACE_API_KEY=your_hf_token_here
HUGGINGFACE_MODEL=facebook/bart-large-mnli
LLM_REQUEST_TIMEOUT=20

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Database
DATABASE_URL=postgresql+asyncpg://shopwave:password@localhost:5432/shopwave

# App Config
WORKER_COUNT=5
CONFIDENCE_THRESHOLD=0.6
ESCALATION_AMOUNT_THRESHOLD=200
MAX_RETRIES=3
MAX_REACT_ITERATIONS=8

# Chaos Config
CHAOS_ENABLED=false
CHAOS_TIMEOUT_RATE=0.15
CHAOS_MALFORMED_RATE=0.10
CHAOS_SERVER_ERROR_RATE=0.15
CHAOS_SUCCESS_RATE=0.60
CHAOS_SEED=2026

# Security
ADMIN_TOKEN=change_me_in_production
